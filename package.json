{
  "name": "ai-agent-based-on-claude",
  "version": "1.0.0",
  "description": "AI Agent based on Claude via the Anthropic API",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "esbuild src/client/index.tsx --bundle --outfile=dist/public/app.js --platform=browser --jsx=automatic --define:process.env.NODE_ENV=\\\"production\\\"",
    "typecheck:client": "tsc -p tsconfig.client.json",
    "typecheck:mcp": "tsc -p tsconfig.mcp.json",
    "mcp": "tsx src/mcp/cli.ts",
    "mcp:demo": "tsx src/mcp/demo.ts",
    "mcp:omdb": "tsx src/mcp/omdb-server.ts",
    "mcp:weather": "tsx src/mcp/weather-server.ts",
    "copy:assets": "cp src/client/index.html dist/public/ && cp src/client/style.css dist/public/",
    "build": "mkdir -p dist/public && pnpm run build:server && pnpm run build:client && pnpm run copy:assets",
    "start": "node dist/server/index.js",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "esbuild src/client/index.tsx --bundle --outfile=dist/public/app.js --platform=browser --jsx=automatic --define:process.env.NODE_ENV=\\\"development\\\" --watch",
    "dev": "mkdir -p dist/public && pnpm run copy:assets && concurrently \"pnpm run dev:server\" \"pnpm run dev:client\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "concurrently": "^8.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
