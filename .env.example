ANTHROPIC_API_KEY=your_api_key_here
PORT=3000
# GitHub Personal Access Token for the GitHub MCP client (github.com/settings/tokens)
GITHUB_PAT=your_github_pat_here
# OMDb API key for the OMDb MCP server (free key at https://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=your_omdb_api_key_here
# weatherstack API key for the Weather MCP server (free key at https://weatherstack.com/)
WEATHERSTACK_API_KEY=your_weatherstack_api_key_here
# currencylayer API key for the Currency MCP server (free key at https://currencylayer.com/)
CURRENCY_API_KEY=your_currencylayer_api_key_here
